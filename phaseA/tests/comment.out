------------------- Lexical Analysis --------------------
2: #1 "2 - 2"  COMMENT NESTED_COMMENT <-enumerated
4: #2 "1 - 4"  COMMENT BLOCK_COMMENT <-enumerated
6: #3 ""  COMMENT LINE_COMMENT <-enumerated
7: #4 "pame"  IDENT "pame" <-char*
7: #5 "katw"  IDENT "katw" <-char*
7: #6 "enter"  IDENT "enter" <-char*
7: #7 "*"  OPERATOR MULT <-enumerated
7: #8 "/"  OPERATOR DIV <-enumerated
9: #9 "9 - 9"  COMMENT BLOCK_COMMENT <-enumerated

